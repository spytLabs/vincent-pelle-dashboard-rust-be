{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "dialog:default",
    "shell:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        {
          "url": "**"
        }
      ]
    }
  ]
}